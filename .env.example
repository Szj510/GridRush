VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Reliable online transport: relay game messages through Supabase Realtime.
# 1 = enabled (recommended for cross-network play), 0 = PeerJS P2P only.
VITE_NET_USE_SUPABASE_RELAY=1

# Optional: custom PeerJS signaling server (recommended if 0.peerjs.com is blocked in your network)
VITE_PEERJS_HOST=
VITE_PEERJS_PORT=
VITE_PEERJS_PATH=/peerjs
VITE_PEERJS_SECURE=true
VITE_PEERJS_KEY=

# Optional: only enable if your own PeerJS server exposes `${VITE_PEERJS_PATH}/peers`
VITE_PEERJS_ENABLE_DISCOVERY=0
